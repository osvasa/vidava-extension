{
  "manifest_version": 3,
  "name": "VIDAVA",
  "version": "1.0",
  "description": "AI at Your Checkout. VIDAVA selects the best card for all of your shopping needs.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content.js", "vidava-overlay.js"]
    }
  ],
  "background": {
    "service_worker": "service-worker.js",
    "scripts": ["lib/supabase.min.js", "supabase-client.js", "background.js"]
  },
  "web_accessible_resources": [
    {
      "resources": ["logo.png", "vidava-logo-animated.gif"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "vidava@vidava.app",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["authenticationInfo", "financialAndPaymentInfo", "websiteActivity"]
      }
    }
  }
}
