{
  "manifest_version": 2,
  "name": "VIDAVA",
  "version": "1.0",
  "description": "AI at Your Checkout. VIDAVA selects the best card for all of your shopping needs.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "identity",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content.js", "vidava-overlay.js"]
    }
  ],
  "background": {
    "scripts": ["lib/supabase.min.js", "supabase-client.js", "background.js"],
    "persistent": true
  },
  "web_accessible_resources": [
    "logo.png",
    "vidava-logo-animated.gif"
  ]
}
